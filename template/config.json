{
    "name": "@fvonts/$font-name",
    "version": "$version",
    "description": "Self-host the $font-name font in a neatly bundled NPM package.",
    "main": "index.css",
    "publishConfig": {"access": "public"},
    "repository": {
      "type": "git",
      "url": "git+$github_repository"
    },
    "keywords": [
      "fvonts",
      "fonts",
      "cdn-font",
      "npm-fvonts",
      "npm-font"
    ],
    "author": "$author",
    "license": "$license",
    "bugs": {
      "url": "$github_repository/issues"
    },
    "homepage": "$github_repository#readme"
  }
  